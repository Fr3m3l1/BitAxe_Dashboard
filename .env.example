# BitAxe Dashboard configuration

# Web UI login code
ACCESS_CODE=change-me

# Shared secret the collector must send as X-API-Key header.
# Generate one with: openssl rand -hex 24
API_KEY=change-me-too

# Session signing key (optional; auto-generated per start if unset)
#SECRET_KEY=

# Telegram notifications (optional)
#TELEGRAM_TOKEN=123456:ABC...
#TELEGRAM_CHAT_ID=123456789

# Storage
#DB_PATH=db/dashboard.db
#RETENTION_DAYS=90
#ALERT_RETENTION_DAYS=30

# Server
#HOST=0.0.0.0
#PORT=5000
